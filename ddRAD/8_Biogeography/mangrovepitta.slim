// mangrove pitta simulation with no genetics
initialize() {
	// define some global constants for parameters
	
	// define mutation rate
	// defineConstant("MU", 4.6e-9);
	
	// define number of mutating sites
	// defineConstant("L", 10000);
	
	// define recombination rate
	// defineConstant("R", 1e-9);
	
	//define population size
	defineConstant("N", 100000);
	
	// define adult death rate
	defineConstant("D", 0.263507866);

	// set model type as non-Wright-Fisher
	initializeSLiMModelType("nonWF");

	// set up model as a spatial simulation
	initializeSLiMOptions(dimensionality="xy");

	//set up sexual model
	initializeSex("A");

	// carrying-capacity density per sqkm
	defineConstant("K", 40); 

	// SIGMA_S, the spatial competition width
	defineConstant("S", 0.1); 

	// spatial competition
	initializeInteractionType(1, "xy", reciprocal=T, maxDistance=S * 3);
	i1.setInteractionFunction("n", 1.0, S);
	// spatial mate choice
	initializeInteractionType(2, "xy", reciprocal=T, maxDistance=0.5);
	i2.setConstraints("receiver", sex="F");
	i2.setConstraints("exerter", sex="M");

	// starting time interval for map choice (depends on BPP results)
	defineConstant("startInt", 508);

	//

	// initializeMutationRate(MU);
	
	// m1 mutation type: neutral
	// initializeMutationType("m1", 0.5, "f", 0.0);
	// m1.convertToSubstitution = T;
	
	// g1 genomic element type: uses m1 for all mutations
	// initializeGenomicElementType("g1", m1, 1.0);
	
	// uniform chromosome of length 100 kb with uniform recombination
	// initializeGenomicElement(g1, 0, L - 1);
	// initializeRecombinationRate(R);
}

1 early() {
	
	// create a population of 500 individuals
	sim.addSubpop("p1", N);

	// set boundaries of the simulation
	p1.setSpatialBounds(c(0.0, 0.0, 4194.0, 4397.0));

	mapImage = Image("~/analysis/pitta/nichemodelling/mangrove_predictions_slim/predicted_interval"+startInt+".png");
	map = p1.defineSpatialMap("SEA", "xy", floor(mapImage.floatK),
		valueRange=c(0.0, 1.0), colors=c("#0000CC", "#55FF22"));

	// start near a specific map location
	for (ind in p1.individuals) {
		do {
			ind.x = runif(1, 828, 905);
			ind.y = runif(1, 3085, 3115);
		}
		while(p1.spatialMapValue("SEA", ind.spatialPosition) == 0.0 | !p1.pointInBounds(ind.spatialPosition));
	}

}

1: late() {
	//if at interval boundary, generate output map and change map
	if(sim.cycle % 1000 == 0 & sim.cycle > 999) {
		intNum = asInteger(startInt - floor(sim.cycle/1000));
		mprange = summarizeIndividuals(p1.individuals, c(4194, 4397), p1.spatialBounds, operation="1;", empty=0.0, perUnitArea=F);
		Image(mprange).write("~/analysis/pitta/nichemodelling/mangrovepitta_range/mprange_interval"+intNum+".png");
		mapImage = Image("~/analysis/pitta/nichemodelling/mangrove_predictions_slim/predicted_interval"+intNum+".png");
		map = p1.defineSpatialMap("SEA", "xy", floor(mapImage.floatK),
			valueRange=c(0.0, 1.0), colors=c("#0000CC", "#55FF22"));
			
		//kill any individuals living on water
		inds = p1.individuals;
		sim.killIndividuals(inds[p1.spatialMapValue("SEA",inds.spatialPosition) == 0]);
	}
	
}

2: first() {
	// look for mates
	i2.evaluate(p1);
}


reproduction(NULL, "F") {
	// choose our nearest neighbor as a mate, within the max distance
	mate = i2.nearestInteractingNeighbors(individual, 1);
	if (mate.size()>0)
		// offspring = subpop.addCrossed(individual, mate, count=rpois(1,1.5));
		subpop.addCrossed(individual, mate, count=rpois(1,1.5));

	// set offspring position
