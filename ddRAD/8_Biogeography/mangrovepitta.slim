modifyChild() {
	do {
		do pos = parent1.spatialPosition + rnorm(2, 0, 8.89);
		while (!p1.pointInBounds(pos));
	} while (p1.spatialMapValue("SEA",pos) == 0.0);

	child.setSpatialPosition(pos);
	return T;
}

early() {
	//perform age-related mortality with killIndividuals
	inds = p1.individuals;
	ages = inds.age;

	inds1 = inds[ages == 1];
	inds2 = inds[ages == 2];
	inds3 = inds[ages == 3];
	inds4 = inds[ages == 4];
	inds5 = inds[ages == 5];
	inds6 = inds[ages == 6];
	inds7 = inds[ages == 7];
	inds8 = inds[ages == 8];
	inds9 = inds[ages >= 9];
	death1 = (runif(inds1.size()) < D);
	death2 = (runif(inds2.size()) < D);
	death3 = (runif(inds3.size()) < D);
	death4 = (runif(inds4.size()) < D);
	death5 = (runif(inds5.size()) < D);
	death6 = (runif(inds6.size()) < D);
	death7 = (runif(inds7.size()) < D);
	death8 = (runif(inds8.size()) < D);
	sim.killIndividuals(c(inds1[death1],inds2[death2],inds3[death3],inds4[death4],inds5[death5],inds6[death6],inds7[death7],inds8[death8],inds9));

	//spatial competition provides density-dependent selection
	i1.evaluate(p1);
	inds = p1.individuals;
	competition = i1.localPopulationDensity(inds);
	inds.fitnessScaling = K / competition;	
}

